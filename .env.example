# =============================================================================
# SwapRunn Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -----------------------------------------------------------------------------
# DATABASE (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string.
# Get this from Railway (Postgres plugin), Neon (neon.tech), or Supabase (supabase.com > Settings > Database)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://user:password@host:5432/swaprunn

# -----------------------------------------------------------------------------
# SESSION (Required)
# -----------------------------------------------------------------------------
# A long, random secret for signing session cookies.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string-at-least-64-chars

# -----------------------------------------------------------------------------
# APP URL (Required in production)
# -----------------------------------------------------------------------------
# The public URL of your deployed app. Used in password reset & invitation emails.
# Example: https://swaprunn.up.railway.app
APP_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# EMAIL (Optional — needed for password reset & invitation emails)
# -----------------------------------------------------------------------------
# Get a free API key at: https://resend.com
# Update the from address in server/email.ts to match your verified Resend domain.
RESEND_API_KEY=re_your_resend_api_key_here

# -----------------------------------------------------------------------------
# FILE UPLOADS (Optional — path for uploaded profile/delivery photos)
# -----------------------------------------------------------------------------
# Uploaded files are saved to disk. On Railway, this persists across deploys.
# Defaults to ./uploads relative to project root if not set.
# UPLOADS_DIR=/absolute/path/to/uploads

# -----------------------------------------------------------------------------
# PUSH NOTIFICATIONS (Optional — for iOS Capacitor push notifications)
# -----------------------------------------------------------------------------
# Only needed if building the native iOS app with Firebase push notifications.
# Paste the entire Firebase service account JSON as a single-line string.
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# -----------------------------------------------------------------------------
# NODE ENV
# -----------------------------------------------------------------------------
NODE_ENV=production
